# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/rignode

# Random secret for session signing (use: openssl rand -hex 32)
SESSION_SECRET=

# Solana wallet address (base58) that receives USDC payments from job fees
# This is a receive-only address - RIGNODE never handles private keys
TREASURY_WALLET=

# Solana network: mainnet-beta or devnet
SOLANA_NETWORK=mainnet-beta

# Optional: override Solana RPC endpoint (defaults to public endpoint)
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
